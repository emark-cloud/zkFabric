{
  "name": "@zkfabric/indexer",
  "version": "0.1.0",
  "private": true,
  "description": "Event-driven Merkle tree indexer for zkFabric. Watches CredentialRegistered on ZKFabricRegistry and exposes the rebuilt leaf list over HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "hono": "^4.6.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
